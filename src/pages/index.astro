---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CatalogoGrid from '../components/CatalogoGrid.astro';
import Orientador from '../components/Orientador.astro';
---
<Base
  titulo="JBD Repuestos en Belén de Escobar | Autopartes y filtros"
  descripcion="Casa de repuestos automotor en Belén de Escobar. Catálogo online de filtros, correas, baterías y más. Consultá stock y precio por WhatsApp."
>
  <Header />
  <main>
    <section class="hero">
      <video class="hero-video" autoplay muted loop playsinline poster="/video/motor-poster.jpg">
        <source src="/video/motor.webm" type="video/webm" />
        <source src="/video/motor.mp4" type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
      <div class="hero-inner">
        <span class="hero-kicker">Belén de Escobar · Zona Norte</span>
        <h1 class="hero-titulo">El repuesto que buscás,<br><span class="acento">sin vueltas</span>.</h1>
        <p class="hero-sub">Filtros, correas, baterías, frenos y más. Mirá el catálogo, consultá stock y precio, y cerrá por WhatsApp.</p>
        <a href="#catalogo" class="hero-scroll">Ver catálogo ↓</a>
      </div>
    </section>

    <Orientador />

    <section class="cat-seccion" id="catalogo">
      <div class="cat-seccion-head">
        <h2>Catálogo</h2>
        <p>Filtrá por marca, tipo o disponibilidad.</p>
      </div>
      <CatalogoGrid />
    </section>
  </main>
  <Footer />
</Base>
<style>
  .hero { position: relative; min-height: 78vh; display: flex; align-items: center; justify-content: center; overflow: hidden; border-bottom: 1px solid var(--borde-card); }
  .hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .hero-overlay { position: absolute; inset: 0; z-index: 1; background: linear-gradient(180deg, rgba(13,13,15,0.72) 0%, rgba(13,13,15,0.55) 45%, rgba(13,13,15,0.92) 100%); }
  .hero-inner { position: relative; z-index: 2; max-width: 760px; padding: var(--esp-16) var(--esp-4); text-align: center; }
  .hero-kicker { display: inline-block; font-size: var(--texto-xs); font-weight: var(--peso-semibold); text-transform: uppercase; letter-spacing: var(--tracking-label); color: var(--color-marca-texto); margin-bottom: var(--esp-4); }
  .hero-titulo { font-size: 52px; font-weight: var(--peso-black); line-height: 1.02; margin-bottom: var(--esp-5); }
  .hero-titulo .acento { color: var(--color-marca); }
  .hero-sub { font-size: var(--texto-cuerpo-lg); color: var(--color-texto-primario); max-width: 52ch; margin: 0 auto var(--esp-8); opacity: 0.9; }
  .hero-scroll { display: inline-flex; align-items: center; min-height: 52px; padding: 14px 28px; font-family: var(--fuente-texto); font-size: var(--texto-cuerpo-lg); font-weight: var(--peso-bold); color: var(--color-texto-primario); border: 1px solid var(--color-texto-secundario); border-radius: var(--radio-md); }
  .hero-scroll:hover { background: rgba(255,255,255,0.1); text-decoration: none; }
  .cat-seccion { max-width: 1180px; margin: 0 auto; padding: var(--esp-12) var(--esp-4) var(--esp-16); scroll-margin-top: 70px; }
  .cat-seccion-head h2 { font-size: var(--texto-display); margin-bottom: var(--esp-2); }
  .cat-seccion-head p { color: var(--color-texto-secundario); margin-bottom: var(--esp-6); }
  @media (max-width: 640px) { .hero-titulo { font-size: 36px; } .hero { min-height: 68vh; } }
</style>