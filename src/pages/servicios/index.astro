---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import negocio from '../../data/negocio.json';

const servicios = [
  {
    titulo: 'Venta por mostrador',
    texto: `Atendemos en ${negocio.direccion.localidad}, en el local. Traé el repuesto viejo o el modelo del auto y te asesoramos ahí mismo.`,
    icono: '<rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>',
  },
  {
    titulo: 'Pedidos por WhatsApp',
    texto: 'Nos escribís con el repuesto o el problema, te confirmamos precio y disponibilidad, y coordinamos el retiro o el envío.',
    icono: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
  },
  {
    titulo: 'Búsqueda de repuestos a pedido',
    texto: 'Si no lo tenemos en stock, lo conseguimos. Trabajamos con proveedores de zona norte y te avisamos apenas llega.',
    icono: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
  },
  {
    titulo: 'Asesoramiento técnico',
    texto: 'Te ayudamos a identificar el repuesto correcto para tu marca y modelo, para que no compres algo que no corresponde.',
    icono: '<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
  },
];

const mensajeWa = 'Hola JBD, quiero consultar por un repuesto. ¿Me ayudan a encontrarlo?';
---
<Base
  titulo={`Servicios | ${negocio.nombre}`}
  descripcion={`Venta de repuestos por mostrador y WhatsApp, búsqueda de repuestos a pedido y asesoramiento técnico en ${negocio.direccion.localidad}.`}
>
  <Header />
  <main class="serv-main">
    <div class="serv-head">
      <h1>Cómo trabajamos</h1>
      <p class="serv-sub">Repuestos para tu auto, sin vueltas: mostrador, WhatsApp y asesoramiento en cada consulta.</p>
    </div>

    <div class="serv-grid">
      {servicios.map(s => (
        <article class="serv-card">
          <span class="serv-icon" set:html={`<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${s.icono}</svg>`} />
          <h2>{s.titulo}</h2>
          <p>{s.texto}</p>
        </article>
      ))}
    </div>

    <section class="serv-cta">
      <h2>¿Buscás un repuesto puntual?</h2>
      <p>Contanos qué auto tenés y qué repuesto necesitás, y te confirmamos precio y stock por WhatsApp.</p>
      <div class="serv-cta-acciones">
        <WhatsAppButton texto="Consultar por WhatsApp" mensaje={mensajeWa} origen="servicios" size="lg" />
        <a class="serv-cta-link" href="/catalogo/">Ver catálogo completo →</a>
      </div>
    </section>
  </main>
  <Footer />
</Base>
<style>
  .serv-main { max-width: 1180px; margin: 0 auto; padding: var(--esp-8) var(--esp-4) var(--esp-16); }
  .serv-head h1 { margin: 0 0 var(--esp-2); font-size: var(--texto-display); }
  .serv-sub { color: var(--color-texto-secundario); max-width: 58ch; margin: 0 0 var(--esp-10); }
  .serv-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--esp-5); margin-bottom: var(--esp-12); }
  .serv-card { background: var(--superficie-card); border: 1px solid var(--borde-card); border-radius: var(--radio-lg); padding: var(--esp-6); }
  .serv-icon { display: inline-flex; align-items: center; justify-content: center; width: 52px; height: 52px; border-radius: var(--radio-md); background: var(--color-marca-tinte); color: var(--color-marca); margin-bottom: var(--esp-4); }
  .serv-card h2 { font-size: var(--texto-h3); margin: 0 0 var(--esp-2); }
  .serv-card p { color: var(--color-texto-secundario); margin: 0; }
  .serv-cta { text-align: center; max-width: 620px; margin: 0 auto; padding: var(--esp-10) var(--esp-4); border-top: 1px solid var(--borde-card); }
  .serv-cta h2 { font-size: var(--texto-h2); margin: 0 0 var(--esp-2); }
  .serv-cta p { color: var(--color-texto-secundario); margin: 0 0 var(--esp-6); }
  .serv-cta-acciones { display: flex; align-items: center; justify-content: center; gap: var(--esp-5); flex-wrap: wrap; }
  .serv-cta-link { color: var(--color-texto-secundario); font-weight: var(--peso-semibold); }
  .serv-cta-link:hover { color: var(--color-marca-texto); }
  @media (max-width: 640px) { .serv-grid { grid-template-columns: 1fr; } }
</style>
