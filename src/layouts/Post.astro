---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import negocio from '../data/negocio.json';

interface Props {
  slug: string;
  titulo: string;
  descripcion: string;
  fecha: Date;
  actualizado?: Date;
  cluster: 'mantenimiento' | 'diagnostico' | 'local' | 'clasicos';
  faqs?: { pregunta: string; respuesta: string }[];
  relacionados?: { slug: string; titulo: string }[];
}

const { slug, titulo, descripcion, fecha, actualizado, cluster, faqs = [], relacionados = [] } = Astro.props;

const CLUSTER_LABEL: Record<string, string> = {
  mantenimiento: 'Mantenimiento',
  diagnostico: 'Diagnóstico',
  local: 'Local',
  clasicos: 'Clásicos',
};

const formateador = new Intl.DateTimeFormat('es-AR', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' });
const fechaFmt = formateador.format(fecha);
const actualizadoFmt = actualizado ? formateador.format(actualizado) : null;
const urlCanonica = `https://jbdrespuestos.com/blog/${slug}/`;

const schemaArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: titulo,
  description: descripcion,
  datePublished: fecha.toISOString(),
  dateModified: (actualizado ?? fecha).toISOString(),
  author: { '@type': 'Organization', name: negocio.razonSocial },
  publisher: { '@type': 'Organization', name: negocio.razonSocial },
  mainEntityOfPage: urlCanonica,
};

const schemaFAQ = faqs.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.pregunta,
        acceptedAnswer: { '@type': 'Answer', text: f.respuesta },
      })),
    }
  : null;

const mensajeWa = `Hola JBD, leí la nota "${titulo}" y quiero consultar por un repuesto.`;
---
<Base titulo={`${titulo} | Blog JBD Repuestos`} descripcion={descripcion}>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(schemaArticle)} />
  {schemaFAQ && <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />}
  <main class="post-main">
    <article class="post">
      <div class="post-head">
        <a class="post-volver" href="/blog/">← Blog</a>
        <span class="post-cluster">{CLUSTER_LABEL[cluster]}</span>
        <h1>{titulo}</h1>
        <p class="post-meta">
          Publicado el {fechaFmt}{actualizadoFmt ? ` · Actualizado el ${actualizadoFmt}` : ''}
        </p>
      </div>
      <div class="post-body">
        <slot />
      </div>
      {relacionados.length > 0 && (
        <div class="post-relacionados">
          <h3>Te puede interesar</h3>
          <ul>
            {relacionados.map((r) => (
              <li><a href={`/blog/${r.slug}/`}>{r.titulo}</a></li>
            ))}
          </ul>
        </div>
      )}
      <div class="post-cta">
        <p>¿Te quedaste con dudas o necesitás el repuesto ya?</p>
        <WhatsAppButton texto="Consultar por WhatsApp" mensaje={mensajeWa} origen="blog" size="lg" />
      </div>
    </article>
  </main>
  <Footer />
</Base>
<style>
  .post-main { max-width: 760px; margin: 0 auto; padding: var(--esp-8) var(--esp-4) var(--esp-16); }
  .post-volver { display: inline-block; font-size: var(--texto-sm); color: var(--color-texto-secundario); margin-bottom: var(--esp-4); }
  .post-volver:hover { color: var(--color-marca-texto); }
  .post-cluster { display: inline-block; font-size: var(--texto-xs); font-weight: var(--peso-bold); text-transform: uppercase; letter-spacing: var(--tracking-label); color: var(--color-marca-texto); margin-bottom: var(--esp-3); }
  .post-head h1 { font-size: var(--texto-display); margin: 0 0 var(--esp-2); }
  .post-meta { color: var(--color-texto-terciario); font-size: var(--texto-sm); margin: 0 0 var(--esp-8); }
  .post-body { color: var(--color-texto-primario); font-size: var(--texto-cuerpo-lg); line-height: var(--interlinea-cuerpo); }
  .post-body :global(h2) { font-size: var(--texto-h2); margin: var(--esp-10) 0 var(--esp-4); }
  .post-body :global(h3) { font-size: var(--texto-h3); margin: var(--esp-8) 0 var(--esp-3); }
  .post-body :global(p) { margin: 0 0 var(--esp-5); }
  .post-body :global(ul), .post-body :global(ol) { margin: 0 0 var(--esp-5); padding-left: 1.3em; }
  .post-body :global(li) { margin-bottom: var(--esp-2); }
  .post-body :global(a) { color: var(--color-marca-texto); }
  .post-body :global(strong) { color: var(--color-texto-primario); }
  .post-relacionados { margin-top: var(--esp-10); padding-top: var(--esp-6); border-top: 1px solid var(--borde-card); }
  .post-relacionados h3 { font-size: var(--texto-h3); margin: 0 0 var(--esp-3); }
  .post-relacionados ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--esp-2); }
  .post-relacionados a { color: var(--color-marca-texto); font-weight: var(--peso-semibold); }
  .post-cta { margin-top: var(--esp-12); padding-top: var(--esp-8); border-top: 1px solid var(--borde-card); text-align: center; }
  .post-cta p { color: var(--color-texto-secundario); margin: 0 0 var(--esp-5); font-size: var(--texto-cuerpo-lg); }
</style>
