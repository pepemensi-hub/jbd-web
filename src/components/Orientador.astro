---
import negocio from '../data/negocio.json';
import { linkWA } from '../lib/whatsapp.js';
import WhatsAppButton from './WhatsAppButton.astro';

const telLimpio = negocio.telefono.replace(/\s/g, '');
const direccionCorta = `${negocio.direccion.calle}, ${negocio.direccion.localidad}`;
const mensajeGenerico = 'Hola JBD, quiero hacer una consulta.';
const waGenerico = linkWA({ whatsapp: negocio.whatsapp, mensaje: mensajeGenerico });

const opciones = [
  { id: 'pedido', label: '¿Cómo hago un pedido?' },
  { id: 'ubicacion', label: '¿Dónde están?' },
  { id: 'whatsapp', label: 'Hablar por WhatsApp' },
  { id: 'telefono', label: 'Llamar por teléfono' },
];
---
<section class="orientador" aria-labelledby="ori-titulo">
  <div class="ori-card">
    <div class="ori-intro">
      <h2 id="ori-titulo">¿Cómo podemos ayudarte?</h2>
      <p class="ori-sub">Elegí una opción y te mostramos la respuesta acá mismo.</p>
    </div>

    <div class="ori-opciones">
      {opciones.map((o) => (
        <button
          type="button"
          class="ori-opcion"
          id={`ori-tab-${o.id}`}
          aria-expanded="false"
          aria-controls={`ori-panel-${o.id}`}
          data-opcion={o.id}
        >
          {o.label}
        </button>
      ))}
    </div>

    <div class="ori-respuestas" aria-live="polite" hidden>
      <div class="ori-panel" id="ori-panel-pedido" data-panel="pedido" aria-labelledby="ori-tab-pedido" hidden>
        <p>Dos formas de pedir: buscá el repuesto en el catálogo de acá abajo y tocá <strong>Agregar</strong>, o contanos directo qué necesitás por WhatsApp.</p>
        <div class="ori-acciones">
          <a class="ori-btn ori-btn-secundario" href="#catalogo" data-ori-scroll>
            Ir al catálogo ↓
          </a>
          <WhatsAppButton texto="Consultar por WhatsApp" mensaje={mensajeGenerico} origen="orientador" size="md" />
        </div>
      </div>

      <div class="ori-panel" id="ori-panel-ubicacion" data-panel="ubicacion" aria-labelledby="ori-tab-ubicacion" hidden>
        <p>Estamos en <strong>{direccionCorta}</strong>.</p>
        <div class="ori-acciones">
          <a class="ori-btn ori-btn-secundario" href="/ubicacion/">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
            Ver en el mapa
          </a>
        </div>
      </div>

      <div class="ori-panel" id="ori-panel-whatsapp" data-panel="whatsapp" aria-labelledby="ori-tab-whatsapp" hidden>
        <p>Escribinos y te respondemos a la brevedad.</p>
        <div class="ori-acciones">
          <a class="ori-btn ori-btn-whatsapp" href={waGenerico} target="_blank" rel="noopener noreferrer" data-wa="orientador">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            Hablar por WhatsApp
          </a>
        </div>
      </div>

      <div class="ori-panel" id="ori-panel-telefono" data-panel="telefono" aria-labelledby="ori-tab-telefono" hidden>
        <p>Podés llamarnos al <strong>{negocio.telefono}</strong>.</p>
        <div class="ori-acciones">
          <a class="ori-btn ori-btn-secundario" href={`tel:${telLimpio}`}>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Llamar ahora
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const orientador = document.querySelector('.orientador');
    if (!orientador) return;

    const tabs = orientador.querySelectorAll('.ori-opcion');
    const panels = orientador.querySelectorAll('.ori-panel');
    const wrap = orientador.querySelector('.ori-respuestas');

    function ocultarTodo() {
      tabs.forEach(function (t) { t.setAttribute('aria-expanded', 'false'); t.classList.remove('activo'); });
      panels.forEach(function (p) { p.hidden = true; });
      wrap.hidden = true;
    }

    function mostrar(id) {
      tabs.forEach(function (t) {
        const activo = t.dataset.opcion === id;
        t.setAttribute('aria-expanded', activo ? 'true' : 'false');
        t.classList.toggle('activo', activo);
      });
      panels.forEach(function (p) {
        p.hidden = p.dataset.panel !== id;
      });
      wrap.hidden = false;
    }

    tabs.forEach(function (t) {
      t.addEventListener('click', function () {
        const yaAbierto = t.getAttribute('aria-expanded') === 'true';
        if (yaAbierto) {
          ocultarTodo();
        } else {
          mostrar(t.dataset.opcion);
        }
      });
    });

    orientador.querySelectorAll('[data-ori-scroll]').forEach(function (a) {
      a.addEventListener('click', function (e) {
        const destino = document.querySelector(a.getAttribute('href'));
        if (destino) {
          e.preventDefault();
          destino.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  })();
</script>

<style>
  .orientador { max-width: 1180px; margin: 0 auto; padding: var(--esp-6) var(--esp-4) 0; }
  .ori-card { background: var(--superficie-card); border: 1px solid var(--borde-card); border-radius: var(--radio-lg); padding: var(--esp-6); }
  .ori-intro h2 { font-size: var(--texto-h2); margin: 0 0 var(--esp-1); }
  .ori-sub { color: var(--color-texto-secundario); font-size: var(--texto-sm); margin: 0 0 var(--esp-5); }

  .ori-opciones { display: flex; flex-wrap: wrap; gap: var(--esp-2); }
  .ori-opcion {
    min-height: 44px;
    padding: 10px 18px;
    border-radius: var(--radio-pill);
    border: 1px solid var(--color-borde-fuerte);
    background: transparent;
    color: var(--color-texto-primario);
    font-family: var(--fuente-texto);
    font-size: var(--texto-sm);
    font-weight: var(--peso-semibold);
    cursor: pointer;
    transition: border-color .12s, background .12s, color .12s;
  }
  .ori-opcion:hover { border-color: var(--color-marca); }
  .ori-opcion.activo { background: var(--color-marca); border-color: var(--color-marca); color: var(--color-texto-sobre-marca); }

  .ori-respuestas { margin-top: var(--esp-5); padding-top: var(--esp-5); border-top: 1px solid var(--borde-card); }
  .ori-panel p { margin: 0 0 var(--esp-4); font-size: var(--texto-cuerpo); color: var(--color-texto-primario); }
  .ori-panel strong { color: var(--color-texto-primario); font-weight: var(--peso-bold); }

  .ori-acciones { display: flex; flex-wrap: wrap; gap: var(--esp-3); }
  .ori-btn { display: inline-flex; align-items: center; gap: 8px; min-height: 44px; padding: 0 18px; border-radius: var(--radio-md); font-family: var(--fuente-texto); font-size: var(--texto-sm); font-weight: var(--peso-semibold); text-decoration: none; }
  .ori-btn-secundario { border: 1px solid var(--color-borde-fuerte); color: var(--color-texto-primario); }
  .ori-btn-secundario:hover { border-color: var(--color-marca); text-decoration: none; }
  .ori-btn-whatsapp { color: var(--color-whatsapp-texto); background: var(--color-whatsapp); }
  .ori-btn-whatsapp:hover { background: var(--color-whatsapp-hover); text-decoration: none; }

  @media (max-width: 640px) {
    .ori-opciones { gap: var(--esp-2); }
    .ori-opcion { flex: 1 1 calc(50% - var(--esp-2)); text-align: center; }
    .ori-acciones { flex-direction: column; align-items: stretch; }
    .ori-btn { justify-content: center; }
  }
</style>
