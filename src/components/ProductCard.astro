---
import StockBadge from './StockBadge.astro';
import negocio from '../data/negocio.json';
import { linkWA } from '../lib/whatsapp.js';
interface Props {
  sku: string; nombre: string; marca: string; modelos?: string[];
  precio: number | null; estado?: 'disponible' | 'pedido' | 'agotado';
}
const { sku, nombre, marca, modelos = [], precio, estado = 'disponible' } = Astro.props;
const agotado = estado === 'agotado';
const precioFmt = precio != null ? '$ ' + precio.toLocaleString('es-AR') : 'Consultar';
const compat = modelos.length ? `${marca} ${modelos.join(', ')}` : marca;
const waUrl = linkWA({ whatsapp: negocio.whatsapp, repuesto: nombre, sku, marca, modelo: modelos.join(', ') });
const clase = agotado ? 'card agotado' : 'card';
const precioAttr = precio == null ? '' : String(precio);
---
<article class={clase}>
  <div class="card-img">
    <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 3v18M3 12h18"/></svg>
  </div>
  <div class="card-body">
    <div class="card-top">
      <StockBadge estado={estado} />
    </div>
    <div>
      <div class="card-marca">{compat}</div>
      <h3 class="card-nombre">{nombre}</h3>
    </div>
    <div class="card-precio">{precioFmt}</div>
    <div class="card-acciones">
      <button class="card-agregar" data-agregar data-sku={sku} data-nombre={nombre} data-compat={compat} data-precio={precioAttr} hidden={agotado}>Agregar</button>
      <a class="card-cta" href={waUrl} target="_blank" rel="noopener noreferrer" data-wa="catalogo" data-sku={sku} aria-label="Consultar por WhatsApp">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      </a>
    </div>
  </div>
</article>
<style>
  .card { display: flex; flex-direction: column; background: var(--superficie-card); border: 1px solid var(--borde-card); border-radius: var(--radio-md); overflow: hidden; box-shadow: var(--sombra-card); }
  .card.agotado { opacity: 0.85; }
  .card-img { aspect-ratio: 4/3; background: var(--color-superficie-alta); display: flex; align-items: center; justify-content: center; color: var(--color-texto-terciario); }
  .card-body { padding: var(--esp-4); display: flex; flex-direction: column; gap: var(--esp-3); }
  .card-top { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
  .card-marca { font-size: var(--texto-xs); letter-spacing: var(--tracking-label); text-transform: uppercase; color: var(--color-texto-secundario); margin-bottom: 2px; }
  .card-nombre { margin: 0; font-family: var(--fuente-display); font-size: var(--texto-h3); font-weight: var(--peso-bold); color: var(--texto-titulo); line-height: var(--interlinea-titulo); }
  .card-precio { font-family: var(--fuente-display); font-size: var(--texto-display); font-weight: var(--peso-black); color: var(--color-marca); line-height: 1; font-variant-numeric: tabular-nums; }
  .card-acciones { display: flex; gap: var(--esp-2); }
  .card-agregar { flex: 1; min-height: 46px; padding: 12px 16px; font-family: var(--fuente-texto); font-size: var(--texto-cuerpo); font-weight: var(--peso-semibold); color: var(--color-texto-primario); background: transparent; border: 1px solid var(--color-borde-fuerte); border-radius: var(--radio-md); cursor: pointer; transition: all .12s; }
  .card-agregar:hover { border-color: var(--color-marca); }
  .card-cta { display: inline-flex; align-items: center; justify-content: center; width: 46px; min-height: 46px; flex-shrink: 0; color: var(--color-whatsapp-texto); background: var(--color-whatsapp); border-radius: var(--radio-md); text-decoration: none; transition: background .12s; }
  .card-cta:hover { background: var(--color-whatsapp-hover); text-decoration: none; }
</style>