---
import negocio from '../data/negocio.json';
const telLimpio = negocio.telefono.replace(/\s/g, '');
---
<header class="site-header">
  <a href="/" class="logo" aria-label="JBD Repuestos - Inicio">
    <span class="logo-nombre">JBD<span class="logo-punto">.</span></span>
    <span class="logo-sub">Repuestos</span>
  </a>
  <nav class="nav">
    <a href="/catalogo/">Catálogo</a>
    <a href="/servicios/">Servicios</a>
    <a href="/blog/">Blog</a>
    <a href="/contacto/">Contacto</a>
  </nav>
  <div class="header-acciones">
    <a class="header-tel" href={`tel:${telLimpio}`} aria-label="Llamar a JBD">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
    </a>
    <button id="header-carrito" class="header-carrito" aria-label="Ver pedido">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
      <span class="header-carrito-count" id="header-carrito-count" hidden>0</span>
    </button>
  </div>
</header>
<style>
  .site-header { display: flex; align-items: center; gap: var(--esp-4); padding: var(--esp-3) var(--esp-4); background: var(--superficie-card); border-bottom: 1px solid var(--borde-card); position: sticky; top: 0; z-index: 50; }
  .logo { display: inline-flex; align-items: baseline; gap: 7px; font-family: var(--fuente-display); line-height: 1; text-decoration: none; flex-shrink: 0; }
  .logo:hover { text-decoration: none; }
  .logo-nombre { font-size: 26px; font-weight: var(--peso-black); letter-spacing: -0.02em; color: var(--color-texto-primario); }
  .logo-punto { color: var(--color-marca); }
  .logo-sub { font-size: 11px; font-weight: var(--peso-bold); letter-spacing: var(--tracking-label); text-transform: uppercase; color: var(--color-texto-secundario); }
  .nav { display: flex; gap: var(--esp-5); margin-left: auto; }
  .nav a { color: var(--color-texto-secundario); font-family: var(--fuente-texto); font-size: var(--texto-sm); font-weight: var(--peso-semibold); text-transform: uppercase; letter-spacing: var(--tracking-label); }
  .nav a:hover { color: var(--color-texto-primario); text-decoration: none; }
  .header-acciones { display: flex; align-items: center; gap: var(--esp-2); }
  .header-tel { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: var(--radio-md); border: 1px solid var(--color-borde-fuerte); color: var(--color-texto-secundario); flex-shrink: 0; }
  .header-tel:hover { color: var(--color-texto-primario); text-decoration: none; }
  .header-carrito { position: relative; display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: var(--radio-md); border: 1px solid var(--color-borde-fuerte); background: transparent; color: var(--color-texto-primario); cursor: pointer; flex-shrink: 0; transition: border-color .12s; }
  .header-carrito:hover { border-color: var(--color-texto-primario); }
  .header-carrito-count { position: absolute; top: -6px; right: -6px; min-width: 20px; height: 20px; padding: 0 5px; border-radius: var(--radio-pill); background: var(--color-marca); color: var(--color-texto-sobre-marca); font-family: var(--fuente-texto); font-size: 11px; font-weight: var(--peso-bold); display: inline-flex; align-items: center; justify-content: center; border: 2px solid var(--superficie-card); }
  @media (max-width: 640px) { .nav { display: none; } }
</style>