---
import negocio from '../data/negocio.json';
const telLimpio = negocio.telefono.replace(/\s/g, '');
---
<header class="site-header">
  <a href="/" class="logo" aria-label="JBD Repuestos - Inicio">
    <span class="logo-nombre">JBD<span class="logo-punto">.</span></span>
    <span class="logo-sub">Repuestos</span>
  </a>

  <nav class="nav">
    <a href="/catalogo/">Catálogo</a>
    <a href="/servicios/">Servicios</a>
    <a href="/blog/">Blog</a>
    <a href="/contacto/">Contacto</a>
  </nav>

  <a class="header-tel" href={`tel:${telLimpio}`} aria-label="Llamar a JBD">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
    </svg>
  </a>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    gap: var(--esp-4);
    padding: var(--esp-3) var(--esp-4);
    background: var(--superficie-card);
    border-bottom: 1px solid var(--borde-card);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .logo {
    display: inline-flex;
    align-items: baseline;
    gap: 7px;
    font-family: var(--fuente-display);
    line-height: 1;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo:hover { text-decoration: none; }
  .logo-nombre {
    font-size: 26px;
    font-weight: var(--peso-black);
    letter-spacing: -0.02em;
    color: var(--color-texto-primario);
  }
  .logo-punto { color: var(--color-marca); }
  .logo-sub {
    font-size: 11px;
    font-weight: var(--peso-bold);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-texto-secundario);
  }
  .nav {
    display: flex;
    gap: var(--esp-5);
    margin-left: auto;
  }
  .nav a {
    color: var(--color-texto-secundario);
    font-family: var(--fuente-texto);
    font-size: var(--texto-sm);
    font-weight: var(--peso-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
  }
  .nav a:hover { color: var(--color-texto-primario); text-decoration: none; }
  .header-tel {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radio-md);
    border: 1px solid var(--color-borde-fuerte);
    color: var(--color-texto-secundario);
    flex-shrink: 0;
  }
  .header-tel:hover { color: var(--color-texto-primario); text-decoration: none; }

  @media (max-width: 640px) {
    .nav { display: none; }
  }
</style>